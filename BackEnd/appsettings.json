{
  "AzureOpenAI": {
    "EmbeddingDeployment": "text-embedding-3-small",
    "EmbeddingEndpoint": "https://your-embedding-resource.cognitiveservices.azure.com",
    "EmbeddingApiKey": "set-via-user-secrets"
  },
  "DebateStyle": {
    "MinTurnDelaySeconds": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
